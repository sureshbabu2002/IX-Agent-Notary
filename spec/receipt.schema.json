{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ix-agent-notary.local/spec/receipt.schema.json",
  "title": "IX-Agent-Notary Receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "receipt_version",
    "receipt_id",
    "time",
    "trace",
    "actor",
    "notary",
    "action",
    "policy",
    "result",
    "integrity"
  ],
  "properties": {
    "receipt_version": { "type": "string", "minLength": 1 },
    "receipt_id": { "type": "string", "minLength": 1 },

    "time": { "$ref": "#/$defs/time" },
    "trace": { "$ref": "#/$defs/trace" },
    "actor": { "$ref": "#/$defs/actor" },
    "notary": { "$ref": "#/$defs/notary" },

    "action": { "$ref": "#/$defs/action" },
    "policy": { "$ref": "#/$defs/policy" },
    "result": { "$ref": "#/$defs/result" },
    "integrity": { "$ref": "#/$defs/integrity" }
  },
  "$defs": {
    "time": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requested_at", "decided_at", "completed_at"],
      "properties": {
        "requested_at": { "type": "string", "format": "date-time" },
        "decided_at": { "type": "string", "format": "date-time" },
        "completed_at": { "type": "string", "format": "date-time" }
      }
    },
    "trace": {
      "type": "object",
      "additionalProperties": false,
      "required": ["trace_id", "step"],
      "properties": {
        "trace_id": { "type": "string", "minLength": 1 },
        "step": { "type": "integer", "minimum": 1 },
        "parent_receipt_id": { "type": "string", "minLength": 1 }
      }
    },
    "actor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "id"],
      "properties": {
        "type": { "type": "string", "minLength": 1 },
        "id": { "type": "string", "minLength": 1 },
        "display": { "type": "string" },
        "session_id": { "type": "string" }
      }
    },
    "notary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["runtime", "version", "instance_id", "environment"],
      "properties": {
        "runtime": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "instance_id": { "type": "string", "minLength": 1 },
        "environment": { "type": "string", "minLength": 1 }
      }
    },
    "action": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "tool", "operation", "parameters", "parameters_hash"],
      "properties": {
        "kind": { "type": "string", "minLength": 1 },
        "tool": { "type": "string", "minLength": 1 },
        "operation": { "type": "string", "minLength": 1 },
        "parameters": {
          "type": "object",
          "additionalProperties": true
        },
        "parameters_hash": { "type": "string", "minLength": 1 }
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["policy_id", "decision", "reason", "rules", "approvals"],
      "properties": {
        "policy_id": { "type": "string", "minLength": 1 },
        "decision": { "type": "string", "enum": ["allow", "deny"] },
        "reason": { "type": "string" },
        "rules": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["rule_id", "effect"],
            "properties": {
              "rule_id": { "type": "string", "minLength": 1 },
              "effect": { "type": "string", "enum": ["allow", "deny"] },
              "explanation": { "type": "string" }
            }
          }
        },
        "approvals": {
          "type": "array",
          "items": {}
        },
        "context_hashes": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },

        "policy_hash": { "type": "string", "minLength": 1 },
        "policy_source": { "type": "string", "minLength": 1 }
      }
    },
    "result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "summary", "output", "output_hash"],
      "properties": {
        "status": { "type": "string", "minLength": 1 },
        "summary": { "type": "string" },
        "output": {},
        "output_hash": { "type": "string", "minLength": 1 }
      }
    },
    "integrity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["canonicalization", "hash", "signature"],
      "properties": {
        "canonicalization": { "type": "string", "minLength": 1 },
        "hash": {
          "type": "object",
          "additionalProperties": false,
          "required": ["alg", "encoding"],
          "properties": {
            "alg": { "type": "string", "minLength": 1 },
            "encoding": { "type": "string", "minLength": 1 }
          }
        },
        "signature": {
          "type": "object",
          "additionalProperties": false,
          "required": ["alg", "key_id", "value"],
          "properties": {
            "alg": { "type": "string", "minLength": 1 },
            "key_id": { "type": "string", "minLength": 1 },
            "value": { "type": "string", "minLength": 1 }
          }
        }
      }
    }
  }
}
